{
  "name": "security-deposit-recovery-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "build:zip": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path security-deposit-recovery.zip) { Remove-Item security-deposit-recovery.zip -Force }; Compress-Archive -Path dist\\* -DestinationPath security-deposit-recovery.zip -Force\"",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "date-fns": "^3.6.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.2.0",
    "zustand": "^4.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  }
}
