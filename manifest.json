{
  "manifest_version": 3,
  "name": "Security Deposit Recovery",
  "description": "Prepare a local security deposit demand letter for all 50 US states.",
  "version": "1.0.0",
  "action": {
    "default_title": "Security Deposit Recovery",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "128": "icons/icon-128.png"
  },
  "options_page": "src/options/index.html",
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": ["storage", "downloads", "notifications"]
}
